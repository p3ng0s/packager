pkgname=qflipper-p3ng0s
pkgver=0.1
pkgrel=1
pkgdesc="qflipper package for p3ng0s"
arch=("any")
options=('!strip')
url="https://flipper.net/pages/downloads"
license=('NONE')

build() {
	curl -s 'https://update.flipperzero.one/builds/qFlipper/1.3.3/qFlipper-x86_64-1.3.3.AppImage' -o qFlipper
}

package() {
	install -D -m755 ./qFlipper $pkgdir/usr/local/bin/qFlipper
}
