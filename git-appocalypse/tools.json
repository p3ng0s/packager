{
	"pentest_tools": [
		{
			"name": "impacket",
			"url": "https://github.com/fortra/impacket",
			"install": [
				"python -m venv .",
				"./bin/pip install -U .",
				"find \"./bin\" -type f -executable -exec sed -i \"1s|#!.*python|#!/opt/pentest/impacket/bin/python|\" {} +"
			]
		},
		{
			"name": "Responder",
			"url": "https://github.com/lgandx/Responder",
			"install": [
				"python -m venv .",
				"./bin/pip install -U .",
				"find \"./bin\" -type f -executable -exec sed -i \"1s|#!.*python|#!/opt/pentest/Responder/bin/python|\" {} +"
			]
		},
		{
			"name": "BloodHound.py",
			"url": "https://github.com/dirkjanm/BloodHound.py",
			"install": [
				"git checkout bloodhound-ce",
				"python -m venv .",
				"./bin/pip install -U .",
				"find \"./bin\" -type f -executable -exec sed -i \"1s|#!.*python|#!/opt/pentest/BloodHound.py/bin/python|\" {} +"
			]
		},
		{
			"name":"conquest-profile-generator",
			"url":"https://github.com/matro7sh/conquest-profile-generator",
			"install": [
				"python -m venv .",
				"./bin/pip install -r ./requirements.txt",
				"find \"./bin\" -type f -executable -exec sed -i \"1s|#!.*python|#!/opt/pentest/conquest-profile-generator/bin/python|\" {} +"
			]
		},
		{
			"name": "precompiled-binaries",
			"url": "https://github.com/jakobfriedl/precompiled-binaries",
			"install": [
			]
		},
		{
			"name": "SecLists",
			"url": "https://github.com/danielmiessler/SecLists",
			"install": [
			]
		}
	],
	"dev_tools": [
		{
			"name": "dwmstat",
			"url": "https://github.com/p4p1/dwmstat",
			"install": [
				"python -m venv .",
				"./bin/pip install -U .",
				"find \"./bin\" -type f -executable -exec sed -i \"1s|#!.*python|#!/opt/dev/dwmstat/bin/python|\" {} +"
			]
		}
	],
	"windows_tools": [
	]
}
